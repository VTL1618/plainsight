{
  "name": "plainsight",
  "version": "0.3.0",
  "description": "Static security scanner for AI agent artifacts: skills, MCP configs, and plugin manifests.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "plainsight": "dist/cli/bin.js"
  },
  "files": [
    "dist",
    "rules",
    "!rules/**/fixtures"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "cli": "tsx src/cli/bin.ts",
    "new-rule": "tsx scripts/new-rule.ts",
    "sweep": "tsx scripts/sweep.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VTL1618/plainsight.git"
  },
  "homepage": "https://github.com/VTL1618/plainsight#readme",
  "bugs": {
    "url": "https://github.com/VTL1618/plainsight/issues"
  },
  "keywords": [
    "security",
    "static-analysis",
    "ai-agents",
    "prompt-injection",
    "claude-skills",
    "mcp",
    "sarif"
  ],
  "dependencies": {
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^9.30.0",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.19.0",
    "ajv": "^8.20.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.30.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0"
  }
}
